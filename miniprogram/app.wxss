/* app.wxss - 全局样式 - 现代化UI */

/* 现代配色变量 */
:root {
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --primary-color: #667eea;
  --secondary-color: #764ba2;
  --accent-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  --success-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  --warning-gradient: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  --danger-gradient: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
  --glass-bg: rgba(255, 255, 255, 0.85);
  --glass-border: rgba(255, 255, 255, 0.5);
}

/* 页面通用样式 */
page {
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
  color: #2c3e50;
  height: 100%;
}

/* 通用容器 - 现代化卡片设计 */
.container {
  padding: 24rpx;
  background: var(--glass-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.1), 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid var(--glass-border);
}

/* 文本溢出省略号 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 清除浮动 */
.clearfix::after {
  content: "";
  display: block;
  clear: both;
  height: 0;
  line-height: 0;
  visibility: hidden;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
}

.flex-around {
  justify-content: space-around;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.margin-top-20 {
  margin-top: 20rpx;
}

.margin-bottom-20 {
  margin-bottom: 20rpx;
}

.margin-20 {
  margin: 20rpx;
}

.padding-20 {
  padding: 20rpx;
}

.padding-top-20 {
  padding-top: 20rpx;
}

.padding-bottom-20 {
  padding-bottom: 20rpx;
}

/* 文本样式 */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: #667eea;
}

.text-danger {
  color: #ff6b6b;
}

.text-success {
  color: #4facfe;
}

.text-warning {
  color: #faad14;
}

.text-muted {
  color: #95a5a6;
}

.text-bold {
  font-weight: bold;
}

.text-lg {
  font-size: 32rpx;
}

.text-sm {
  font-size: 24rpx;
}

/* 按钮样式 - 现代化渐变按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
  white-space: nowrap;
  vertical-align: middle;
  cursor: pointer;
  user-select: none;
  border: none;
  border-radius: 48rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.btn:active::before {
  opacity: 1;
}

.btn-primary {
  color: #fff;
  background: var(--primary-gradient);
  border: none;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.btn-default {
  color: #2c3e50;
  background: #fff;
  border: 2rpx solid #e9ecef;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-default:active {
  color: #667eea;
  border-color: #667eea;
  transform: scale(0.96);
}

.btn-danger {
  color: #fff;
  background: var(--danger-gradient);
  border: none;
}

.btn-sm {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.btn-lg {
  padding: 30rpx 60rpx;
  font-size: 32rpx;
}

/* 列表样式 */
.list-item {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
  margin-left: 20rpx;
}

.list-item-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999;
}

.list-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 20rpx;
}

.input-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  background-color: #fff;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #40a9ff;
  outline: none;
}

/* 加载中样式 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #999;
}

/* 空状态样式 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 20rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-button {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  color: #1890ff;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
}

/* 标签样式 - 现代化渐变标签 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 32rpx;
  margin-right: 10rpx;
  transition: all 0.3s ease;
}

.tag-primary {
  color: #fff;
  background: var(--primary-gradient);
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.tag-success {
  color: #fff;
  background: var(--success-gradient);
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(79, 172, 254, 0.3);
}

.tag-warning {
  color: #fff;
  background: var(--warning-gradient);
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(250, 112, 154, 0.3);
}

.tag-danger {
  color: #fff;
  background: var(--danger-gradient);
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}

/* 徽标样式 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  font-size: 20rpx;
  color: #fff;
  background-color: #ff4d4f;
  border-radius: 16rpx;
  line-height: 1;
}

/* 全局图片默认样式，防止图片加载失败 */
image {
  display: block;
  background-color: #f5f5f5;
}

/* 商品图默认背景 - 现代渐变 */
.default-product {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 分类图标默认背景 */
.default-category {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

/* 轮播图默认背景 */
.banner-image {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 头像默认背景 */
.default-avatar {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

/* 图标默认背景 */
.order-icon,
.menu-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

/* 空状态图片 */
.empty-icon,
.empty-image {
  background: linear-gradient(135deg, #e0e0e0 0%, #f5f5f5 100%);
}

/* 玻璃拟态效果 */
.glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

/* 阴影系统 */
.shadow-sm {
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.08);
}

.shadow-md {
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.12);
}

.shadow-lg {
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.16);
}

/* 悬浮效果 */
.hover-lift {
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
}

.hover-lift:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.2);
}