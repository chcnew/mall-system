/* pages/index/index.wxss - 现代化首页 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  padding-bottom: 120rpx;
}

/* 玻璃拟态搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
}

.search-input {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
}

.search-input:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.8);
}

.search-text {
  flex: 1;
  font-size: 28rpx;
  color: #95a5a6;
  margin-left: 12rpx;
  font-weight: 400;
}

/* 现代轮播图 */
.banner-swiper {
  width: 100%;
  height: 360rpx;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  position: relative;
  overflow: hidden;
}

.banner-placeholder::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(25%, 25%); }
}

/* 分类区域 - 现代卡片 */
.categories-section {
  margin: 20rpx 24rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

.categories-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  transition: transform 0.3s ease;
}

.category-item:active {
  transform: scale(0.95);
}

.category-placeholder {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(240, 147, 251, 0.3);
  transition: all 0.3s ease;
}

.category-item:active .category-placeholder {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(240, 147, 251, 0.4);
}

.category-name {
  font-size: 24rpx;
  color: #5a6c7d;
  font-weight: 500;
}

/* 商品区域 */
.hot-section,
.new-section {
  margin: 20rpx 24rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.products-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.simple-product {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.simple-product:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.15);
}

.product-placeholder {
  width: 100%;
  height: 220rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(79, 172, 254, 0.2);
}

.product-name {
  font-size: 26rpx;
  color: #2c3e50;
  line-height: 1.5;
  height: 76rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.1);
}