/* pages/product/index.wxss - 现代化商品详情页 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  padding-bottom: 120rpx;
}

/* 商品主图 */
.product-images {
  width: 100%;
  height: 750rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.2);
}

.main-image {
  width: 100%;
  height: 100%;
}

/* 商品基本信息 - 玻璃拟态卡片 */
.product-basic {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 36rpx 24rpx;
  margin: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 28rpx;
}

.price-main {
  display: flex;
  align-items: baseline;
}

.current-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #667eea;
  margin-right: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.1);
}

.original-price {
  font-size: 28rpx;
  color: #bdc3c7;
  text-decoration: line-through;
}

.sold-info {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #95a5a6;
}

.product-meta {
  margin-bottom: 32rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  border-radius: 32rpx;
  margin-right: 12rpx;
  font-weight: 600;
}

.tag-hot {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(240, 147, 251, 0.3);
}

.tag-new {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(79, 172, 254, 0.3);
}

.product-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.product-subtitle {
  font-size: 26rpx;
  color: #7f8c8d;
  line-height: 1.4;
}

/* 规格选择区域 */
.sku-section {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  margin: 0 24rpx 24rpx;
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.sku-container {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.sku-block {
  margin-bottom: 28rpx;
}

.block-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.sku-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sku-option {
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(102, 126, 234, 0.1);
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #2c3e50;
  transition: all 0.3s ease;
}

.sku-option:active {
  transform: scale(0.95);
}

.sku-option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 数量选择区域 */
.quantity-section {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  margin: 0 24rpx 24rpx;
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.quantity-control {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.qty-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f6fa 0%, #e8ecef 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.qty-btn:active {
  transform: scale(0.9);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.qty-btn:active .btn-icon {
  color: #fff;
}

.btn-icon {
  font-size: 40rpx;
  color: #2c3e50;
  font-weight: 600;
  transition: color 0.3s ease;
}

.qty-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
  min-width: 80rpx;
}

.stock-hint {
  text-align: center;
  font-size: 24rpx;
  color: #f39c12;
  margin-top: 20rpx;
  padding: 12rpx 24rpx;
  background: rgba(243, 156, 18, 0.1);
  border-radius: 48rpx;
  display: inline-block;
}

/* 底部操作栏 - 玻璃拟态 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 -8rpx 32rpx rgba(102, 126, 234, 0.12);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.favorite-btn,
.cart-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(102, 126, 234, 0.05);
  transition: all 0.3s ease;
}

.favorite-btn:active,
.cart-btn:active {
  transform: scale(0.9);
  background: rgba(102, 126, 234, 0.15);
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
}

.buy-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.buy-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.5);
}

/* 图片列表 */
.images-section {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  margin: 0 24rpx 24rpx;
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.image-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  padding-bottom: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.image {
  width: 100%;
  padding-bottom: 100%;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f5f6fa 0%, #e8ecef 100%);
  transition: transform 0.3s ease;
}

.image-item:active .image {
  transform: scale(1.05);
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 20rpx;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  animation: rotate 1s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #95a5a6;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 规格选择弹窗 */
.sku-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.6);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sku-modal {
  width: 640rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 36rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.modal-close {
  padding: 8rpx;
  transition: transform 0.3s ease;
}

.modal-close:active {
  transform: rotate(90deg);
}

.close-icon {
  width: 32rpx;
  height: 32rpx;
}

.modal-content {
  max-height: 60vh;
  overflow-y: auto;
  padding-bottom: 20rpx;
}

.selected-info {
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 24rpx;
}

.info-label {
  margin-right: 8rpx;
}

.info-content {
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.info-empty {
  color: #bdc3c7;
}

.sku-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.sku-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.sku-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sku-item {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #2c3e50;
  transition: all 0.3s ease;
  border: 2rpx solid rgba(102, 126, 234, 0.1);
}

.sku-item:active {
  transform: scale(0.95);
}

.sku-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.sku-text {
  margin-left: 8rpx;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.5);
}

.modal-close-btn,
.modal-confirm-btn {
  padding: 20rpx 40rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: none;
  line-height: 1;
  transition: all 0.3s ease;
}

.modal-close-btn {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.modal-close-btn:active {
  background: rgba(102, 126, 234, 0.2);
}

.modal-confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.modal-confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

/* 通用 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 默认图片 */
.default-product {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f5f6fa 0%, #e8ecef 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #bdc3c7;
}
