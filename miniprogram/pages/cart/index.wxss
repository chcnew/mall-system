/* pages/cart/index.wxss - 现代化购物车 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  padding-bottom: 120rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 20rpx;
}

.empty-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  font-size: 80rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.empty-text {
  font-size: 28rpx;
  color: #7f8c8d;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.empty-actions {
  display: flex;
  gap: 20rpx;
}

/* 顶部工具栏 - 玻璃拟态 */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.05);
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #bdc3c7;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  background: #fff;
}

.checkbox.checked {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.checkbox text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.select-text {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 500;
}

.toolbar-actions {
  display: flex;
  gap: 20rpx;
}

.edit-text,
.delete-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  transition: opacity 0.3s ease;
}

.edit-text:active,
.delete-text:active {
  opacity: 0.7;
}

/* 购物车列表 */
.cart-content {
  padding: 24rpx;
}

.cart-list {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.cart-item {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: background 0.3s ease;
}

.cart-item:active {
  background: rgba(102, 126, 234, 0.02);
}

.cart-item:last-child {
  border-bottom: none;
}

.item-checkbox {
  padding: 0 20rpx 0 0;
  display: flex;
  align-items: center;
}

.item-product-info {
  flex: 1;
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.5;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.1);
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.quantity-btn:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: scale(0.9);
}

.quantity-btn:active text {
  color: #fff;
}

.btn-icon {
  width: 24rpx;
  height: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  transition: color 0.3s ease;
}

.quantity-value {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

/* 编辑模式 */
.edit-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
}

.edit-item:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
  margin: 0 20rpx;
  overflow: hidden;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f5f6fa 0%, #e8ecef 100%);
}

.item-detail {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 120rpx;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 500;
}

.item-specs {
  font-size: 24rpx;
  color: #95a5a6;
}

.item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

.item-quantity {
  font-size: 24rpx;
  color: #95a5a6;
}

/* 底部结算栏 - 玻璃拟态 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 -8rpx 32rpx rgba(102, 126, 234, 0.12);
}

.bottom-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.selected-count {
  font-size: 24rpx;
  color: #95a5a6;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
  text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.1);
}

.bottom-right {
  display: flex;
}

.checkout-btn {
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.checkout-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.5);
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 20rpx;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #95a5a6;
}