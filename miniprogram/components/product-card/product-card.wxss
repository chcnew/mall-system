/* components/product-card/product-card.wxss - 现代化商品卡片 */
.product-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.1), 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.product-card:active {
  transform: translateY(-8rpx);
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.2);
}

.product-image-container {
  position: relative;
  width: 100%;
  padding-top: 100%;
  overflow: hidden;
}

.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f5f6fa 0%, #e8ecef 100%);
  transition: transform 0.4s ease;
}

.product-card:active .product-image {
  transform: scale(1.05);
}

.product-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  z-index: 2;
}

.tag {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  border-radius: 32rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tag-new {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
}

.tag-hot {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.sold-out {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(44, 62, 80, 0.6);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
  transition: all 0.3s ease;
}

.sold-out-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 48rpx;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.5;
  height: 84rpx;
  margin-bottom: 12rpx;
  font-weight: 600;
  transition: color 0.3s ease;
}

.product-card:active .product-name {
  color: #667eea;
}

.product-desc {
  font-size: 24rpx;
  color: #95a5a6;
  line-height: 1.4;
  height: 34rpx;
  margin-bottom: 20rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.current-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  text-shadow: 0 2rpx 4rpx rgba(102, 126, 234, 0.1);
}

.original-price {
  font-size: 24rpx;
  color: #bdc3c7;
  text-decoration: line-through;
}

.product-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.favorite-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.3s ease;
}

.favorite-btn:active {
  transform: scale(1.1);
}

.favorite-icon {
  width: 36rpx;
  height: 36rpx;
}

.favorite-active {
  filter: brightness(0) invert(0.4);
}

.add-cart-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.add-cart-btn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

.cart-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 动画效果 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-4rpx); }
  20%, 40%, 60%, 80% { transform: translateX(4rpx); }
}

.shake {
  animation: shake 0.5s ease-in-out;
}

/* 新增：悬浮效果 */
.product-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.15);
}